# Copie este arquivo para .env e preencha com os valores do seu App no Entra ID.
# NÃO comite o .env (ele está no .gitignore).

# ID do diretório (locatário) do Entra ID
TENANT_ID=cole-aqui-o-tenant-id

# ID do aplicativo (cliente) do App registrado
CLIENT_ID=cole-aqui-o-client-id

# Escopos delegados do Microsoft Graph (separados por espaço).
# offline_access é adicionado automaticamente pelo MSAL no device flow.
# Para a Fase 2 (Teams), acrescente: Team.ReadBasic.All Channel.ReadBasic.All ChannelMessage.Read.All Chat.Read
GRAPH_SCOPES=Tasks.Read Group.Read.All User.Read User.ReadBasic.All Team.ReadBasic.All Channel.ReadBasic.All ChannelMessage.Read.All Chat.Read

# Seu nome de exibicao (para a secao "Minha agenda operacional do dia")
MY_DISPLAY_NAME=Seu Nome Aqui

# (Opcional) Caminho do arquivo de contexto operacional para a IA.
# Padrao: context.md na raiz. Copie context.example.md -> context.md e preencha.
# EXTRA_CONTEXT_FILE=context.md
